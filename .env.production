# 公開用の環境変数ファイル。ビルド時に NEXT_PUBLIC_ で始まる環境変数は JS バンドルに埋め込まれるため、公開しても問題ない値のみを記載すること。

# バックエンドAPIのURL
NEXT_PUBLIC_API_URL=https://auth.freeeagle.info
NEXT_PUBLIC_DIARY_URL=https://api.freeeagle.info
NEXT_PUBLIC_DIARY_ANALYSIS_URL=https://analysis.freeeagle.info

NEXT_PUBLIC_COOKIE_DOMAIN=freeeagle.info